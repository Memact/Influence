{
  "name": "memact-influence",
  "private": true,
  "version": "0.0.0",
  "description": "Memact Influence engine for deterministic thought-shaping patterns.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "./src/engine.mjs",
  "exports": {
    ".": "./src/engine.mjs",
    "./cli": "./src/cli.mjs"
  },
  "keywords": [
    "influence",
    "transitions",
    "deterministic",
    "capture",
    "memory",
    "analysis"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Memact/Influence.git"
  },
  "homepage": "https://github.com/Memact/Influence",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "memact-influence": "./src/cli.mjs"
  },
  "scripts": {
    "check": "node ./scripts/check.mjs",
    "analyze": "node ./src/cli.mjs",
    "sample": "node ./src/cli.mjs --input examples/sample-capture-snapshot.json --format report",
    "sample:all": "node ./src/cli.mjs --input examples/sample-capture-snapshot.json --format all",
    "pitch": "node ./scripts/pitch-report.mjs"
  }
}
